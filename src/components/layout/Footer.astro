---
// src/components/layout/Footer.astro
// Sofía Castañeda LP footer: contact channels + responsible-use note + privacidad link.

import { site } from '../../data/site';
import { contact, waLink, mailLink } from '../../data/contact';

const baseUrl = import.meta.env.BASE_URL;
const baseTrimmed = baseUrl.replace(/\/$/, '');
const internal = (p: string) => {
  const path = p.replace(/^\//, '');
  return path === '' ? `${baseTrimmed}/` : `${baseTrimmed}/${path}`;
};

const waHref = waLink('Hola Sofía, me gustaría agendar una sesión');
---
<footer class="site-footer">
  <div class="container footer-inner">

    <ul class="contact-row" role="list" aria-label="Canales de contacto">
      <li><a href={waHref} target="_blank" rel="noopener noreferrer">WhatsApp 314 406 8637</a></li>
      <li><a href={mailLink('Consulta — acompañamiento psicológico')}>{contact.email}</a></li>
    </ul>

    <p class="note">
      Este es un espacio de acompañamiento psicológico y no reemplaza una atención de urgencias.
      Si estás en una crisis o emergencia, comunícate con la línea 123 o la Línea de Salud Mental 106.
    </p>

    <p class="brand-line">
      <span class="wordmark">{site.name}</span>
      <span class="separator">·</span>
      <span class="muted">{site.year}</span>
      <span class="separator">·</span>
      <a class="privacy-link" href={internal('/privacidad')}>Tratamiento de datos</a>
    </p>

  </div>
</footer>

<style>
  .site-footer {
    margin-top: 0;
    padding-block: 40px;
    border-top: 1px solid var(--color-chrome-border);
    background: var(--color-beige);
  }
  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
  }
  .contact-row {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .contact-row a {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--color-ink);
    transition: color 200ms ease;
  }
  .contact-row a:hover,
  .contact-row a:focus-visible {
    color: var(--color-terracota);
  }
  .note {
    margin: 0;
    max-width: 44rem;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: var(--color-text-subtle);
  }
  .brand-line {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
    justify-content: center;
  }
  .wordmark {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.05rem;
    letter-spacing: 0.01em;
    color: var(--color-ink);
  }
  .muted { color: var(--color-text-muted); }
  .separator { opacity: 0.5; }
  .privacy-link {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    transition: color 200ms ease;
  }
  .privacy-link:hover,
  .privacy-link:focus-visible {
    color: var(--color-terracota);
  }

  @media (prefers-reduced-motion: reduce) {
    .contact-row a,
    .privacy-link {
      transition: none;
    }
  }
</style>
