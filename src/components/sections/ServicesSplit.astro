---
// src/components/sections/ServicesSplit.astro
// Phase 2 (CONT-01 home step 3): grid de 2 service cards. 1col mobile, 2col tablet+.
// Patrón adaptado de src/pages/obras.astro líneas 188–202 (grid 3col — aquí cap a 2col).
// Helper BASE_URL aplicado a hrefs internos.

import ServiceTeaser from './ServiceTeaser.astro';

interface ServiceCard {
  slug: string;
  label: string;
  teaser: string;
  ctaLabel: string;
}
interface Props {
  services: ServiceCard[];
}
const { services } = Astro.props as Props;

const baseUrl = import.meta.env.BASE_URL;
const baseTrimmed = baseUrl.replace(/\/$/, '');
const internal = (p: string) => {
  const path = p.replace(/^\//, '');
  return path === '' ? `${baseTrimmed}/` : `${baseTrimmed}/${path}`;
};
---
<section class="services-split">
  <div class="container">
    <ul class="services-grid" role="list">
      {services.map(s => (
        <li>
          <ServiceTeaser
            title={s.label}
            teaser={s.teaser}
            ctaLabel={s.ctaLabel}
            ctaHref={internal(`/${s.slug}`)}
          />
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .services-split { padding-block: var(--space-section); }
  .services-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  @media (min-width: 640px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
