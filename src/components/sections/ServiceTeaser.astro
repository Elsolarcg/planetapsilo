---
// src/components/sections/ServiceTeaser.astro
// Phase 2 (CONT-01 home services split, D-22 Claude discretion sobre elemento H3).
// Title a --font-display-lg weight 500 (H3) — regla de jerarquía UI-SPEC: el peso diferencia H2 (300) vs H3 (500) al mismo tamaño.
// CTA es tertiary text-link (UI-SPEC §"ServiceTeaser CTA" labels LOCKED por card).

import Button from '../ui/Button.astro';

interface Props {
  title: string;
  teaser: string;
  ctaLabel: string;
  ctaHref: string;
}
const { title, teaser, ctaLabel, ctaHref } = Astro.props as Props;
---
<article class="service-teaser">
  <h3>{title}</h3>
  <p class="teaser">{teaser}</p>
  <Button variant="tertiary" href={ctaHref} label={ctaLabel} />
</article>

<style>
  .service-teaser {
    padding: 32px 24px;
    background: var(--color-bg-elevated);
    border-radius: 12px;
    border: 1px solid var(--color-chrome-border);
    display: flex;
    flex-direction: column;
    gap: 16px;
    text-align: left;
  }
  h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.625rem, 4vw, 2rem); /* --font-display-lg */
    line-height: 1.25;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0;
  }
  .teaser {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.0625rem; /* --font-body-md 17px */
    line-height: 1.6;
    color: var(--color-text-muted);
    margin: 0;
  }
</style>
