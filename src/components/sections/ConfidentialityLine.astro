---
// src/components/sections/ConfidentialityLine.astro
// Phase 2 D-27: una sola frase de confidencialidad en display-md italic centrada (CONT-09).
// Copy LOCKED: "Lo que se conversa aquí no sale de aquí. Trabajamos con discreción profesional y archivamos sólo lo mínimo necesario."

interface Props {
  text: string;
}
const { text } = Astro.props as Props;
---
<section class="confidentiality">
  <div class="container">
    <p>{text}</p>
  </div>
</section>

<style>
  .confidentiality { padding-block: var(--space-section); }
  p {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.25rem, 3vw, 1.875rem); /* --font-display-md */
    line-height: 1.3;
    text-align: center;
    color: var(--color-text-muted);
    margin: 0 auto;
    max-width: 36rem;
  }
</style>
