---
// src/components/sections/Testimonial.astro
// Phase 2 D-11 / D-12 / CONT-07: 1 testimonial card por página (rotación por contexto).
// Quote en Fraunces italic display-md (coincide con rol tipográfico de máxima / confidentiality).
// Disclaimer requerido mientras los testimonios sean placeholders (Phase 3 LEGAL-07 los reemplaza con consentidos reales).

interface Props {
  quote: string;
  attribution: string;
  disclaimer?: string;
}
const { quote, attribution, disclaimer } = Astro.props as Props;
---
<section class="testimonial">
  <div class="container">
    <figure>
      <blockquote class="quote">
        <p>“{quote}”</p>
      </blockquote>
      <figcaption>
        <p class="attribution">{attribution}</p>
        {disclaimer && <p class="disclaimer">{disclaimer}</p>}
      </figcaption>
    </figure>
  </div>
</section>

<style>
  .testimonial { padding-block: var(--space-section); }
  figure {
    max-width: 36rem;
    margin: 0 auto;
    text-align: center;
  }
  .quote { margin: 0; }
  .quote p {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.25rem, 3vw, 1.875rem); /* --font-display-md */
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0;
  }
  figcaption {
    margin-top: 24px;
  }
  .attribution {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.875rem;  /* --font-body-sm 14px */
    line-height: 1.5;
    letter-spacing: 0.02em;
    color: var(--color-text-primary);
    margin: 0;
  }
  .disclaimer {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 0.8125rem; /* --font-body-xs 13px */
    line-height: 1.5;
    color: var(--color-text-subtle);
    margin: 16px auto 0;
    max-width: 30rem;
  }
</style>
