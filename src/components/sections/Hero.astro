---
// src/components/sections/Hero.astro
// Phase 2 hero — extracted from Phase 1 inline pattern en src/pages/index.astro líneas 13–74.
// Variantes: 'home' (min 100vh, opacity 0.85, máxima permitida) / 'interior' (min 60vh, opacity 0.5, sin máxima).
// Reduced-motion: la animación de .hero-bg ya está desactivada globalmente en tokens.css; no se requiere override aquí.

interface Props {
  variant: 'home' | 'interior';
  kicker?: string;
  title: string;
  maxim?: string;
  lead?: string;
}
const { variant, kicker, title, maxim, lead } = Astro.props as Props;
---
<section class:list={['hero', `hero--${variant}`]}>
  <div class="hero-bg" aria-hidden="true"></div>
  <div class="noise-overlay" aria-hidden="true"></div>
  <div class="container hero-content">
    {kicker && <p class="kicker">{kicker}</p>}
    <h1>{title}</h1>
    {maxim && <p class="maxim">{maxim}</p>}
    {lead && <p class="lead">{lead}</p>}
    <slot />
  </div>
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero--home    { min-height: min(100vh, 720px); }
  .hero--interior{ min-height: min(60vh, 520px); }
  .hero-bg {
    position: absolute;
    inset: -10%;
    z-index: -2;
  }
  .hero--home .hero-bg     { opacity: 0.85; }
  .hero--interior .hero-bg { opacity: 0.5; }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-block: var(--space-section);
  }

  .kicker {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1.125rem; /* --font-display-sm 18px */
    letter-spacing: 0.16em;
    text-transform: lowercase;
    color: var(--color-text-primary);
    opacity: 0.85;
    margin: 0 0 24px;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 5.5vw, 4.5rem); /* --font-display-xl */
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin: 0 0 24px;
    max-width: 32rem;
    margin-inline: auto;
  }

  .maxim {
    font-family: var(--font-display);
    font-weight: 300;
    font-style: italic;
    font-size: clamp(1.25rem, 3vw, 1.875rem); /* --font-display-md */
    line-height: 1.3;
    letter-spacing: -0.005em;
    color: var(--color-text-muted);
    margin: 0 auto 32px;
    max-width: 28rem;
  }

  .lead {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.1875rem; /* --font-body-lg 19px */
    line-height: 1.5;
    color: var(--color-text-muted);
    margin: 0 auto;
    max-width: 36rem;
  }
</style>
