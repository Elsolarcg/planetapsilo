---
// src/components/forms/FormSuccess.astro
// Inline post-submit state that replaces the form node. No redirect, no toast.

import { contact } from '../../data/contact';
---
<div class="form-success" role="status" aria-live="polite">
  <h3>Mensaje recibido.</h3>
  <p>Te respondo lo antes posible, normalmente el mismo día. Si prefieres, también puedes agendar tu llamada gratuita ahora →</p>
  <a
    class="cta-tertiary"
    href={contact.schedulingUrl}
    target="_blank"
    rel="noopener noreferrer"
  >
    Agenda una llamada gratuita
  </a>
</div>

<style>
  .form-success {
    padding: 24px;
    border-radius: 12px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-chrome-border);
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
  }
  .form-success h3 {
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1.5rem, 4vw, 1.875rem);
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0 0 16px;
  }
  .form-success p {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 16px;
  }
  .cta-tertiary {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.0625rem;
    color: var(--color-terracota);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    transition: color 200ms ease;
  }
  .cta-tertiary:hover, .cta-tertiary:focus-visible {
    color: var(--color-terracota-deep);
  }
  @media (prefers-reduced-motion: reduce) {
    .cta-tertiary { transition: none; }
  }
</style>
