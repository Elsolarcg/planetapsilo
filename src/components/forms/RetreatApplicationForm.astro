---
// src/components/forms/RetreatApplicationForm.astro
// Phase 2 (CONT-03, D-07, D-08, D-09, D-10): 5-question application form for /retiros.
// NO Calendly direct (D-07 application gate). Web3Forms POST + inline success swap (no redirect).
// Spinner respects prefers-reduced-motion (UI-SPEC §"Motion" line 497).

import FormField from './FormField.astro';
import HabeasDataCheckbox from './HabeasDataCheckbox.astro';
import FormSuccess from './FormSuccess.astro';
import { contact, waLink } from '../../data/contact';

const errorWaHref = waLink('Hola planetapsilo, intenté la aplicación a retiros y no funcionó');
---
<section id="aplicacion" class="application-section">
  <div class="container narrow">
    <h2>Aplica para un próximo retiro</h2>
    <p class="lead">Recibimos pocas aplicaciones por convocatoria. Si lo que ofrecemos te resuena, cuéntanos de ti.</p>

    <form
      id="retreat-form"
      action="https://api.web3forms.com/submit"
      method="POST"
      class="retreat-form"
    >
      <input type="hidden" name="access_key" value={contact.web3formsKeyRetiros} />
      <input type="hidden" name="subject" value="Aplicación retiro planetapsilo" />
      <input type="hidden" name="from_name" value="planetapsilo retiros form" />
      <input
        type="text"
        name="botcheck"
        tabindex="-1"
        autocomplete="off"
        style="display:none"
        aria-hidden="true"
      />

      <FormField type="text" name="name" label="Nombre" required={true} />
      <FormField type="email" name="email" label="Email" required={true} />
      <FormField type="tel" name="whatsapp" label="WhatsApp" required={true} helpText="Incluye indicativo (+57…)" />
      <FormField type="text" name="referral" label="¿Cómo te enteraste de planetapsilo?" required={true} />
      <FormField type="textarea" name="motivation" label="¿Qué te trae a este momento?" required={true} rows={3} helpText="Una o dos líneas bastan." />
      <FormField
        type="radio"
        name="priorExperience"
        label="¿Has participado antes en espacios similares?"
        required={true}
        options={['Sí', 'No', 'Prefiero no responder']}
      />

      <HabeasDataCheckbox />

      <div id="retreat-error" class="form-error" role="alert" hidden>
        No pudimos enviar. Intenta de nuevo o
        <a href={errorWaHref} target="_blank" rel="noopener noreferrer">escríbenos por WhatsApp</a>.
      </div>

      <button type="submit" class="cta cta-primary" id="retreat-submit">
        <span class="submit-label">Enviar aplicación</span>
        <svg class="spinner" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true" hidden>
          <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2.5" fill="none" stroke-dasharray="40" stroke-dashoffset="20" />
        </svg>
      </button>

      <p class="sla">Respondemos antes de 24h, normalmente el mismo día.</p>
    </form>

    <div id="retreat-success" hidden>
      <FormSuccess variant="retiros" />
    </div>
  </div>
</section>

<style>
  .application-section { padding-block: var(--space-section); }
  .container.narrow {
    max-width: 36rem;
    margin-inline: auto;
  }
  h2 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.625rem, 4vw, 2rem); /* --font-display-lg */
    line-height: 1.2;
    color: var(--color-text-primary);
    margin: 0 0 16px;
    text-align: center;
  }
  .lead {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-muted);
    margin: 0 0 48px;
    text-align: center;
  }
  .retreat-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }
  .form-error {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    line-height: 1.5;
    color: rgba(255, 122, 61, 0.85);
    padding: 12px 16px;
    background: rgba(255, 122, 61, 0.08);
    border-radius: 8px;
  }
  .form-error a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.0625rem;
    letter-spacing: 0.02em;
    line-height: 1.4;
    text-align: center;
    text-decoration: none;
    padding: 12px 28px;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    box-sizing: border-box;
  }
  .cta:focus-visible {
    outline: 2px solid var(--color-orange-mystic);
    outline-offset: 2px;
  }
  .cta-primary {
    background: var(--color-orange-mystic);
    color: var(--color-bg-base);
    box-shadow: 0 8px 24px rgba(255, 122, 61, 0.35);
    transition: transform 200ms ease, opacity 200ms ease;
  }
  .cta-primary:hover:not([disabled]) { transform: scale(1.02); }
  .cta-primary[disabled] { opacity: 0.5; cursor: not-allowed; }
  .spinner {
    animation: spin 800ms linear infinite;
    transform-origin: center;
  }
  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .sla {
    font-family: var(--font-body);
    font-size: 0.875rem; /* 14px */
    color: var(--color-text-muted);
    margin: 0;
    text-align: center;
  }
  @media (prefers-reduced-motion: reduce) {
    .cta-primary { transition: none; }
    .cta-primary:hover { transform: none; }
    .spinner { animation: none; }
  }
</style>

<script>
  // Vanilla JS submit handler — pattern carried from src/components/layout/Nav.astro lines 126-147.
  // Phase 2 D-09: swap form node with FormSuccess inline. No redirect, no toast.
  const form = document.getElementById('retreat-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('retreat-submit') as HTMLButtonElement | null;
  const successBlock = document.getElementById('retreat-success');
  const errorBlock = document.getElementById('retreat-error');

  if (form && submitBtn && successBlock && errorBlock) {
    const submitLabel = submitBtn.querySelector('.submit-label') as HTMLElement | null;
    const spinner = submitBtn.querySelector('.spinner') as HTMLElement | null;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorBlock.hidden = true;
      submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = 'Enviando…';
      if (spinner) spinner.hidden = false;

      try {
        const res = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          form.hidden = true;
          successBlock.hidden = false;
          successBlock.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        } else {
          throw new Error(`non-2xx: ${res.status}`);
        }
      } catch (err) {
        errorBlock.hidden = false;
        submitBtn.disabled = false;
        if (submitLabel) submitLabel.textContent = 'Enviar aplicación';
        if (spinner) spinner.hidden = true;
      }
    });
  }
</script>
