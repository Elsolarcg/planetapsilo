---
// src/pages/index.astro — Home (Phase 2)
// Implementa CONT-01 (hero + dual CTA), CONT-06 (CTABlock), CONT-07 (testimonial), CONT-08 (FAQ), CONT-12 (meta).
// Orden de secciones LOCKED en UI-SPEC §"Per-page section composition `/` (home)".

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import BrandBio from '../components/sections/BrandBio.astro';
import ServicesSplit from '../components/sections/ServicesSplit.astro';
import Testimonial from '../components/sections/Testimonial.astro';
import FAQ from '../components/sections/FAQ.astro';
import CTABlock from '../components/sections/CTABlock.astro';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';
import { faqs } from '../data/faqs';
import { contact, waLink } from '../data/contact';

const homeTestimonial = testimonials.find(t => t.context === 'home');

// Helper BASE_URL para el target del tertiary form-link CTA.
const baseUrl = import.meta.env.BASE_URL;
const baseTrimmed = baseUrl.replace(/\/$/, '');
const contactForm = `${baseTrimmed}/contacto#form`;
const retirosHref = `${baseTrimmed}/retiros`;

// Párrafos LOCKED de BrandBio (UI-SPEC §"Locked strings"). Ambos contienen la cláusula-denial "No es terapia" — la exención del linter copy se maneja en Plan 06.
const brandBioParagraphs = [
  'planetapsilo es un espacio de exploración personal para liderazgos que están reordenando. No es terapia ni servicio de salud — es acompañamiento y retiros pensados para mentes que ya construyeron mucho y ahora quieren ver desde otra altura.',
  'Cada propuesta recibe a pocas personas. Hay una conversación antes — para saber si lo que pides y lo que ofrecemos calzan. La pausa real no se improvisa.',
];
---
<BaseLayout
  description="Acompañamiento y retiros para liderazgos que están reordenando. Espacio de exploración personal para C-Level, founders y nómadas digitales."
>
  <Hero
    variant="home"
    kicker="planetapsilo"
    title="Acompañamiento y retiros para liderazgos que están reordenando."
    maxim="La claridad no se conquista. Se recuerda."
  >
    <div class="hero-cta-row">
      <a
        class="cta cta-primary"
        href={contact.calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Agenda una conversación
      </a>
      <a
        class="cta cta-secondary"
        href={retirosHref}
      >
        Explora los retiros
      </a>
    </div>
  </Hero>

  <BrandBio paragraphs={brandBioParagraphs} />

  <ServicesSplit services={services} />

  {homeTestimonial && (
    <Testimonial
      quote={homeTestimonial.quote}
      attribution={homeTestimonial.attribution}
      disclaimer={homeTestimonial.disclaimer}
    />
  )}

  <FAQ items={faqs} />

  <CTABlock
    primary={{
      label: 'Agenda una conversación',
      href: contact.calendlyUrl,
      external: true,
    }}
    secondary={{
      label: 'Escribir por WhatsApp',
      href: waLink('Hola planetapsilo, me interesa explorar'),
      external: true,
      ariaLabel: 'Escribir a planetapsilo por WhatsApp',
    }}
    tertiary={{
      label: 'Prefiero escribir un formulario',
      href: contactForm,
    }}
  />
</BaseLayout>

<style>
  /* Hero dual CTA — usa .cta-primary + .cta-secondary inline para evitar un 2do import de Button en la página misma.
     Las reglas visuales coinciden con Button.astro primary/secondary exactamente (UI-SPEC §"Button variants" — 12px 28px, pill 999px, 17px Inter 500). */
  .hero-cta-row {
    margin-top: 32px;
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .cta {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.0625rem;
    letter-spacing: 0.02em;
    line-height: 1.4;
    text-align: center;
    text-decoration: none;
    padding: 12px 28px;
    border-radius: 999px;
    box-sizing: border-box;
  }
  .cta:focus-visible {
    outline: 2px solid var(--color-orange-mystic);
    outline-offset: 2px;
  }
  .cta-primary {
    background: var(--color-orange-mystic);
    color: var(--color-bg-base);
    box-shadow: 0 8px 24px rgba(255, 122, 61, 0.35);
    transition: transform 200ms ease;
  }
  .cta-primary:hover { transform: scale(1.02); }
  .cta-primary:active { transform: scale(0.99); }
  .cta-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-text-primary);
    transition: background-color 200ms ease;
  }
  .cta-secondary:hover { background: rgba(244, 237, 227, 0.08); }

  @media (prefers-reduced-motion: reduce) {
    .cta-primary, .cta-secondary { transition: none; }
    .cta-primary:hover, .cta-primary:active { transform: none; }
  }
</style>
