---
// src/pages/index.astro — Home
// Phase 1 stub: hero with .hero-bg animated cosmic gradient (D-04) + wordmark kicker
// + placeholder máxima. Phase 2 (CONT-01) replaces with real value-prop + dual CTA.
// Copy aquí es PLACEHOLDER intencional — Phase 2 inserta copy real validada contra glosario.

import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Inicio"
  description="planetapsilo — espacio de exploración y acompañamiento. (Sitio en construcción.)"
>
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="noise-overlay" aria-hidden="true"></div>
    <div class="container hero-content">
      <p class="kicker">planetapsilo</p>
      <h1 class="hero-headline">
        Un espacio de exploración<br />en construcción.
      </h1>
      <p class="hero-sub">
        Esqueleto Phase 1 — copy real, retiros, acompañamiento y contacto llegan en Phase 2.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: min(100vh, 720px);
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: -10%;
    z-index: -2;
    opacity: 0.85;
  }
  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding-block: var(--space-section);
  }
  .kicker {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 1.125rem;
    letter-spacing: 0.16em;
    text-transform: lowercase;
    color: var(--color-text-primary);
    opacity: 0.8;
    margin-bottom: 1.5rem;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    letter-spacing: -0.01em;
    color: var(--color-text-primary);
    margin-bottom: 1.5rem;
  }
  .hero-sub {
    font-family: var(--font-body);
    font-size: 1rem;
    max-width: 36rem;
    margin-inline: auto;
    color: var(--color-text-muted);
  }
</style>
