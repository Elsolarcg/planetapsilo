---
// src/pages/404.astro — Custom 404. Astro emits dist/404.html which GitHub Pages serves for unmatched routes.
import BaseLayout from '../layouts/BaseLayout.astro';

const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
---
<BaseLayout title="Página no encontrada" description="404 — la ruta que buscas no existe.">
  <section class="not-found">
    <div class="container nf-content">
      <p class="kicker">404</p>
      <h1>Esta página no existe.</h1>
      <p class="lede">El enlace que seguiste no lleva a ningún sitio. Volvamos al inicio.</p>
      <a class="cta-back" href={homeHref}>Vuelve al inicio →</a>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: flex;
    align-items: center;
  }
  .nf-content { text-align: center; padding-block: var(--space-section); }
  .kicker {
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 0.875rem;
    letter-spacing: 0.28em;
    color: var(--color-terracota);
    margin-bottom: 1.25rem;
  }
  h1 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    color: var(--color-ink);
    max-width: 28rem;
    margin: 0 auto 1.25rem;
    line-height: 1.2;
  }
  .lede { color: var(--color-text-muted); max-width: 28rem; margin: 0 auto 2.5rem; }
  .cta-back {
    display: inline-block;
    padding: 12px 28px;
    border-radius: 999px;
    background: var(--color-terracota);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-weight: 500;
  }
  .cta-back:hover { background: var(--color-terracota-deep); color: var(--color-cream); }
</style>
