---
// src/pages/privacidad.astro — Aviso breve de tratamiento de datos (Ley 1581 de 2012).
// Versión inicial; puede ampliarse con revisión legal más adelante.

import BaseLayout from '../layouts/BaseLayout.astro';
import { waLink } from '../data/contact';

const baseUrl = import.meta.env.BASE_URL;
const homeHref = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
const waHref = waLink('Hola Sofía, una consulta sobre el tratamiento de mis datos');
---
<BaseLayout
  title="Tratamiento de datos"
  description="Cómo se tratan los datos personales que dejas en la página de Sofía Castañeda, conforme a la Ley 1581 de 2012."
>
  <section class="legal">
    <div class="container narrow">
      <h1>Tratamiento de datos personales</h1>
      <p>
        Los datos que compartas en esta página (nombre, correo, número de WhatsApp y el mensaje de tu consulta) se usan con una única finalidad: <strong>responderte y coordinar tu acompañamiento psicológico</strong>. No se venden, no se comparten con terceros con fines comerciales y no se usan para publicidad.
      </p>
      <p>
        El tratamiento se realiza conforme a la <strong>Ley 1581 de 2012</strong> y sus normas reglamentarias. En cualquier momento puedes pedir conocer, actualizar, rectificar o eliminar tus datos escribiendo a
        <a href={`mailto:a.castanedav@uniandes.edu.co`}>a.castanedav@uniandes.edu.co</a>.
      </p>
      <p>
        Lo que se conversa en las sesiones se maneja con confidencialidad profesional y se guarda solo lo mínimo necesario para acompañar tu proceso.
      </p>
      <p class="links">
        <a class="link" href={waHref} target="_blank" rel="noopener noreferrer">Escríbeme por WhatsApp</a>
        <span class="sep" aria-hidden="true">·</span>
        <a class="link" href={homeHref}>Vuelve al inicio</a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .legal { padding-block: clamp(5rem, 12vw, 9rem); }
  .container.narrow { max-width: 42rem; }
  h1 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0 0 32px;
  }
  p {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin: 0 0 20px;
  }
  strong { color: var(--color-ink); font-weight: 500; }
  a { color: var(--color-terracota); text-decoration: underline; text-underline-offset: 3px; }
  .links { margin-top: 32px; display: flex; gap: 14px; align-items: center; flex-wrap: wrap; }
  .link { font-weight: 500; }
  .sep { color: var(--color-text-subtle); }
</style>
