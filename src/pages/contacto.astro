---
// src/pages/contacto.astro — Phase 2 (CONT-04, CONT-12)
// 4 sections per UI-SPEC §"/contacto — 4 sections": Hero · Channel duo · ContactForm · (inline success)
// D-15: 2 big buttons side-by-side (not 3 equal cards — Pitfall #9 mitigation).
// D-18: SLA microcopy below each CTA.

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import ContactForm from '../components/forms/ContactForm.astro';
import { contact, waLink } from '../data/contact';

const waHref = waLink('Hola planetapsilo, quiero conversar');
---
<BaseLayout
  title="Contacto"
  description="Tres formas de empezar una conversación con planetapsilo. Agenda directo, escríbenos por WhatsApp o déjanos un mensaje."
>
  <Hero
    variant="interior"
    title="Contacto"
    lead="Tres formas de empezar. Elige la que te calce."
  />

  <section class="channel-duo">
    <div class="container narrow">
      <div class="duo-row">
        <div class="channel">
          <a
            class="cta cta-primary"
            href={contact.calendlyUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Agenda una conversación
          </a>
          <p class="sla">Espacios próximos esta semana</p>
        </div>
        <div class="channel">
          <a
            class="cta cta-secondary"
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Escribir a planetapsilo por WhatsApp"
          >
            Escribir por WhatsApp
          </a>
          <p class="sla">Respondemos antes de 24h</p>
        </div>
      </div>
    </div>
  </section>

  <ContactForm />
</BaseLayout>

<style>
  .channel-duo { padding-block: var(--space-section); }
  .container.narrow {
    max-width: 56rem;
    margin-inline: auto;
  }
  .duo-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 640px) {
    .duo-row { grid-template-columns: 1fr 1fr; gap: 24px; }
  }
  .channel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 32px 24px;
    background: var(--color-bg-elevated);
    border-radius: 12px;
    border: 1px solid var(--color-chrome-border);
    min-height: 160px;
    justify-content: center;
  }
  .cta {
    display: inline-block;
    font-family: var(--font-body);
    font-weight: 500;
    font-size: 1.0625rem;
    letter-spacing: 0.02em;
    line-height: 1.4;
    text-align: center;
    text-decoration: none;
    padding: 12px 28px;
    border-radius: 999px;
    box-sizing: border-box;
    min-width: 12rem;
  }
  .cta:focus-visible {
    outline: 2px solid var(--color-orange-mystic);
    outline-offset: 2px;
  }
  .cta-primary {
    background: var(--color-orange-mystic);
    color: var(--color-bg-base);
    box-shadow: 0 8px 24px rgba(255, 122, 61, 0.35);
    transition: transform 200ms ease;
  }
  .cta-primary:hover { transform: scale(1.02); }
  .cta-secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-text-primary);
    transition: background-color 200ms ease;
  }
  .cta-secondary:hover { background: rgba(244, 237, 227, 0.08); }
  .sla {
    font-family: var(--font-body);
    font-size: 0.875rem; /* --font-body-sm 14px */
    color: var(--color-text-muted);
    margin: 0;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-primary, .cta-secondary { transition: none; }
    .cta-primary:hover { transform: none; }
  }
</style>
