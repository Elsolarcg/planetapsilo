---
// src/pages/acompanamiento.astro — Phase 2 (CONT-02, CONT-09, CONT-12)
// Section order LOCKED in UI-SPEC §"/acompanamiento — 7 sections":
//   1 Hero interior · 2 Para quién · 3 Qué pasa en un encuentro · 4 Cómo funciona el proceso
//   · 5 Testimonial · 6 ConfidentialityLine · 7 CTABlock
// Copy within docs/copy-glossary.md PERMITIDO; denial-clauses ("no es terapia") exempted in Plan 06 linter.

import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/sections/Hero.astro';
import Testimonial from '../components/sections/Testimonial.astro';
import ConfidentialityLine from '../components/sections/ConfidentialityLine.astro';
import CTABlock from '../components/sections/CTABlock.astro';
import { services } from '../data/services';
import { testimonials } from '../data/testimonials';
import { contact, waLink } from '../data/contact';

const acomp = services.find(s => s.slug === 'acompanamiento')!;
const testimonial = testimonials.find(t => t.context === 'acompanamiento');

const baseUrl = import.meta.env.BASE_URL;
const baseTrimmed = baseUrl.replace(/\/$/, '');
const contactForm = `${baseTrimmed}/contacto#form`;

// 3-step proceso — Claude v1 within glosario PERMITIDO; Sofía refines wording.
const procesoSteps = [
  {
    name: 'Una conversación inicial',
    body: 'Antes de cualquier encuentro hay una conversación de 30 minutos para saber si lo que pides y lo que ofrecemos calzan. Sin compromiso.',
  },
  {
    name: 'Encuentros sostenidos',
    body: 'Si decidimos seguir, agendamos encuentros semanales, quincenales o mensuales según tu momento. Cada uno dura entre 60 y 90 minutos, online o presencial en Bogotá.',
  },
  {
    name: 'Revisión cada cierto tiempo',
    body: 'Cada pocos encuentros nos detenemos a mirar el proceso completo — qué cambió, qué sigue, qué dejó de tener sentido. Tú decides cuándo cierra.',
  },
];
---
<BaseLayout
  title="Acompañamiento"
  description="Encuentros uno-a-uno para C-Level, founders y nómadas digitales que están reordenando algo importante. No es terapia — es acompañamiento no clínico."
>
  <Hero
    variant="interior"
    title="Acompañamiento"
    lead="Conversaciones sostenidas para mentes que ya construyeron mucho y ahora necesitan ver desde otra altura."
  />

  <section class="content-section para-quien">
    <div class="container narrow">
      <h2>Para quién</h2>
      <p>{acomp.audience}</p>
    </div>
  </section>

  <section class="content-section que-pasa">
    <div class="container narrow">
      <h2>Qué pasa en un encuentro</h2>
      <ul class="bullets" role="list">
        {acomp.outcomes!.map(o => <li>{o}</li>)}
      </ul>
    </div>
  </section>

  <section class="content-section como-funciona">
    <div class="container narrow">
      <h2>Cómo funciona el proceso</h2>
      <ol class="steps">
        {procesoSteps.map((step, i) => (
          <li>
            <span class="step-num" aria-hidden="true">{i + 1}</span>
            <div class="step-body">
              <h3>{step.name}</h3>
              <p>{step.body}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {testimonial && (
    <Testimonial
      quote={testimonial.quote}
      attribution={testimonial.attribution}
      disclaimer={testimonial.disclaimer}
    />
  )}

  <ConfidentialityLine text={acomp.confidentialityLine!} />

  <CTABlock
    primary={{
      label: 'Agenda una conversación',
      href: contact.calendlyUrl,
      external: true,
    }}
    secondary={{
      label: 'Escribir por WhatsApp',
      href: waLink('Hola planetapsilo, me interesa explorar el acompañamiento'),
      external: true,
      ariaLabel: 'Escribir a planetapsilo por WhatsApp sobre acompañamiento',
    }}
    tertiary={{
      label: 'Prefiero escribir un formulario',
      href: contactForm,
    }}
  />
</BaseLayout>

<style>
  .content-section { padding-block: var(--space-section); }
  .container.narrow {
    max-width: 42rem;
    margin-inline: auto;
  }
  h2 {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: clamp(1.625rem, 4vw, 2rem); /* --font-display-lg */
    line-height: 1.2;
    letter-spacing: -0.005em;
    color: var(--color-text-primary);
    margin: 0 0 32px;
  }
  p {
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.0625rem; /* --font-body-md 17px */
    line-height: 1.65;
    color: var(--color-text-primary);
    margin: 0 0 24px;
  }
  p:last-child { margin-bottom: 0; }

  .bullets {
    list-style: none;
    padding-left: 0;
    margin: 0;
  }
  .bullets li {
    position: relative;
    padding-left: 28px;
    font-family: var(--font-body);
    font-weight: 400;
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--color-text-primary);
    margin-bottom: 16px;
  }
  .bullets li::before {
    content: '◆';
    position: absolute;
    left: 0;
    top: 0;
    color: var(--color-orange-mystic);
    font-size: 0.85em;
    line-height: inherit;
  }

  .steps {
    list-style: none;
    padding-left: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  .steps > li {
    display: grid;
    grid-template-columns: 48px 1fr;
    gap: 24px;
    align-items: start;
  }
  .step-num {
    font-family: var(--font-display);
    font-weight: 300;
    font-size: 2rem;
    line-height: 1;
    color: var(--color-orange-mystic);
  }
  .step-body h3 {
    font-family: var(--font-display);
    font-weight: 500;
    font-style: italic;
    font-size: clamp(1.25rem, 3vw, 1.875rem); /* --font-display-md */
    line-height: 1.3;
    color: var(--color-text-primary);
    margin: 0 0 8px;
  }
  .step-body p { margin: 0; }
</style>
